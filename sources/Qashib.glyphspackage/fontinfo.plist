	;

	sub	[alef-ar.isol alef-ar.fina alef-ar.fina.short]
		[beh-ar.init beh-ar.init.high]
		[twodotsabove-ar threedotsabove-ar]' lookup vert_dots
	;

	sub	[beh-ar.init beh-ar.init.high beh-ar.medi beh-ar.medi.high]
		[twodotsbelow-ar threedotsbelow-ar]' lookup vert_dots
		[beh-ar.medi beh-ar.medi.high
		 reh-ar.fina lam-ar.fina noon-ar.fina yeh-ar.fina yeh-ar.fina.salt]
	;

	sub	[beh-ar.init beh-ar.init.high beh-ar.medi beh-ar.medi.high
		 tah-ar.init tah-ar.init.hah1 tah-ar.init.hah2 tah-ar.medi tah-ar.medi.hah1 tah-ar.medi.hah2
