	;
} rclt_hist_center_dot;

lookup hist_dots {
	sub dotabove-ar			by dotabove-ar.hist;
	sub dotbelow-ar			by dotbelow-ar.hist;
	sub twodotsabove-ar		by twodotsabove-ar.hist;
	sub twodotsbelow-ar		by twodotsbelow-ar.hist;
	sub threedotsabove-ar	by threedotsabove-ar.hist;
	sub threedotsbelow-ar	by threedotsbelow-ar.hist;
} hist_dots;

lookup rclt_hist_sheen_dots {
	lookupflag UseMarkFilteringSet [threedotsabove-ar.hist];

	sub [seen-ar.init]
		[threedotsabove-ar.hist]'
	by	[threedotshorizontalabove-ar.hist]
	;

	sub [seen-ar.medi]
		[threedotsabove-ar.hist]'
	by	[threedotshorizontalabove-ar.hist.mid]
	;

	sub [seen-ar.isol seen-ar.fina]
		[threedotsabove-ar.hist]'
	by	[threedotshorizontalabove-ar.hist.fin]
	;
} rclt_hist_sheen_dots;

@beh_dots = [dotabove-ar.hist twodotsabove-ar.hist threedotsabove-ar.hist
			 twodotsbelow-ar.hist threedotsbelow-ar.hist];
lookup rclt_hist_beh_dots {
	lookupflag UseMarkFilteringSet @beh_dots;

	sub [beh-ar.isol yeh-ar.isol yeh-ar.fina
		 yeh-ar.isol.salt yeh-ar.fina.salt]
		 @beh_dots'
	by	[dotabove-ar.hist.beh twodotsabove-ar.hist.beh threedotsabove-ar.hist.beh
		 twodotsbelow-ar.hist.beh threedotsbelow-ar.hist.beh]
	;

	sub	[reh-ar.isol.hist reh-ar.fina.hist]
		 dotabove-ar.hist'
	by	 dotabove-ar.hist.reh
	;


	sub	[noon-ar.isol.hist noon-ar.fina.hist]
		 dotabove-ar.hist'
	by	 dotabove-ar.hist.noon
	;
} rclt_hist_beh_dots;

